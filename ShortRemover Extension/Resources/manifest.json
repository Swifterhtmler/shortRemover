{
  "manifest_version": 3,
  "name": "Short Remover",
  "version": "1.0",
  "description": "Blocks YouTube Shorts",
  "action": {
     "default_popup": "popup.html",
     "default_icon": "Icon-32.png"
   },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["declarativeNetRequest", "storage", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}
